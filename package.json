{
	"name": "minixlsx",
	"version": "0.1.1",
	"description": "Librería mínima sin dependencias para crear y leer archivos Excel (.xlsx) en Node.js",
	"keywords": [
		"excel",
		"spreadsheet",
		"typescript",
		"xlsx",
		"zero-dependencies"
	],
	"homepage": "https://github.com/4a4c53/minixlsx#readme",
	"bugs": "https://github.com/4a4c53/minixlsx/issues",
	"license": "MIT",
	"author": "José Luis Silva <joseluis@4a4c53.com> (http://4a4c53.com)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/4a4c53/minixlsx.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"imports": {
		"#minixlsx/*": "./src/*.ts"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"test": "node --test",
		"typecheck": "tsc",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"build": "tsc -p tsconfig.build.json && node scripts/fix-dist-imports.ts",
		"prepublishOnly": "pnpm build"
	},
	"devDependencies": {
		"@types/node": "26.1.0",
		"oxfmt": "0.57.0",
		"oxlint": "1.72.0",
		"typescript": "6.0.3"
	},
	"engines": {
		"node": ">=22.18"
	},
	"packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
