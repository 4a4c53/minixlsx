{
	"compilerOptions": {
		"target": "ES2023",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"lib": ["ES2023"],
		"types": ["node"],
		"strict": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"erasableSyntaxOnly": true,
		"skipLibCheck": true
	},
	"include": ["index.ts", "src/**/*.ts", "test/**/*.ts", "examples/**/*.ts", "scripts/**/*.ts"]
}
